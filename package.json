{
  "name": "webpack-jarvis",
  "version": "0.3.2",
  "description": "A very intelligent webpack dashboard",
  "main": "dist/server/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "precommit": "lint-staged",
    "contributors:add": "all-contributors add",
    "contributors:generate": "all-contributors generate",
    "prebuild": "rimraf dist",
    "copy:server": "ncp src/server dist/server",
    "copy:assets": "ncp src/index.html dist/index.html && ncp src/assets dist/assets",
    "build": "webpack --mode=production --config config/webpack && npm run copy:server && npm run copy:assets",
    "watch": "cross-env JARVIS_ENV=development webpack --watch --config config/webpack"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zouhir/jarvis.git"
  },
  "license": "MIT",
  "author": {
    "email": "zouhir@zouhir.org",
    "name": "Zouhir",
    "url": "https://zouhir.org"
  },
  "peerDependencies": {
    "webpack": ">=4.0.0"
  },
  "dependencies": {
    "ansi-to-html": "^0.7.2",
    "import-from": "^4.0.0",
    "obj-str": "^1.0.3",
    "parse-authors": "^0.2.4",
    "polka": "^0.5.2",
    "react-favicon": "^0.0.18",
    "serve-static": "^2.2.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "terser-webpack-plugin": "^5.3.9",
    "url-loader": "^4.1.1"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "@babel/core": "^7.22.5",
    "@babel/plugin-proposal-decorators": "^7.22.5",
    "@babel/plugin-transform-object-assign": "^7.22.5",
    "@babel/plugin-transform-react-constant-elements": "^7.22.5",
    "@babel/plugin-transform-react-jsx": "^7.22.5",
    "@babel/preset-env": "^7.22.5",
    
    "all-contributors-cli": "^6.26.1",
    "autoprefixer": "^10.4.14",
    "babel-loader": "^9.1.2",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "file-loader": "^6.2.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.2",
    "mini-css-extract-plugin": "^2.7.6",
    "ncp": "^2.0.0",
    "postcss-loader": "^8.1.1",
    "preact": "^10.15.1",
    "preact-habitat": "^3.2.0",
    "preact-markup": "^2.1.1",
    "prettier": "^2.8.8",
    "raw-loader": "^4.0.2",
    "sass": "^1.63.4",
    "sass-loader": "^16.0.5",
    "style-loader": "^3.3.3",
    "svg-url-loader": "^8.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-middleware": "^7.4.2",
    "webpack-hot-middleware": "^2.25.4"
  },
  "lint-staged": {
    "src/**/*.{js,json,scss}": [
      "prettier --write",
      "git add"
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "IE >= 10"
  ]
}
